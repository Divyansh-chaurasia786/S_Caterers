{
  "version": 2,
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|images|videos|fonts|build)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_KEY": "base64:LREC/2lhfmqQ/M2MSS2UsZuMWYcXlTGMGtedY7/Yd6U=",
    "APP_ENV": "production",
    "APP_URL": "https://scaterers.vercel.app",
    "APP_DEBUG": "true",
    "LOG_CHANNEL": "stderr",
    "DB_CONNECTION": "sqlite",
    "DB_DATABASE": "/tmp/database/database.sqlite",
    "SESSION_DRIVER": "array",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "APP_PACKAGES_CACHE": "/tmp/bootstrap/cache/packages.php",
    "APP_SERVICES_CACHE": "/tmp/bootstrap/cache/services.php",
